# Meridian AI Governance Platform — Environment Variables
# Copy to .env and fill in your values

# ─── REQUIRED ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # Powers AI Advisor + policy generation
DATABASE_URL=postgresql://meridian:changeme@localhost:5432/meridian
REDIS_URL=redis://:changeme@localhost:6379
JWT_SECRET=generate_with_openssl_rand_base64_32

# ─── API SERVER ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development                   # development | production
LOG_LEVEL=info                         # debug | info | warn | error
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── DATABASE ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_in_production
REDIS_PASSWORD=changeme_in_production

# ─── INTEGRATIONS ────────────────────────────────────────────────────────
# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_GOVERNANCE_CHANNEL=#ai-governance

# Jira
JIRA_HOST=https://your-org.atlassian.net
JIRA_EMAIL=governance@your-org.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=AISGOV

# ServiceNow
SERVICENOW_INSTANCE=your-org.service-now.com
SERVICENOW_USERNAME=...
SERVICENOW_PASSWORD=...

# Okta / Azure AD
OKTA_DOMAIN=your-org.okta.com
OKTA_CLIENT_ID=...
OKTA_CLIENT_SECRET=...
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...

# OneTrust
ONETRUST_API_KEY=...
ONETRUST_BASE_URL=https://your-org.onetrust.com

# AuditBoard
AUDITBOARD_CLIENT_ID=...
AUDITBOARD_CLIENT_SECRET=...

# OpenAI (for usage monitoring)
OPENAI_ADMIN_KEY=sk-...

# ─── FRONTEND ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# ─── DEPLOYMENT ──────────────────────────────────────────────────────────
# Vercel
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...

# Railway (alternative)
RAILWAY_TOKEN=...
